server {
    server_name perumahanbintarojaya.com www.perumahanbintarojaya.com;

    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    location /uploads/ {
        alias /home/Steven1/rumahbintaro/public/uploads/;
        access_log off;
        expires max;
    }


    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/perumahanbintarojaya.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/perumahanbintarojaya.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}
server {
    if ($host = www.perumahanbintarojaya.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = perumahanbintarojaya.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name perumahanbintarojaya.com www.perumahanbintarojaya.com;
    return 404; # managed by Certbot




}